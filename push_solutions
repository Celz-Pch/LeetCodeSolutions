#!/usr/bin/env python3

import re
import subprocess
import sys
from pathlib import Path


def get_unpushed_files() -> list[str]:
    result = subprocess.run(
        ["git", "status", "--short"],
        capture_output=True, text=True, check=True
    )
    files = []
    for line in result.stdout.splitlines():
        status = line[:2]
        filepath = line[3:].strip()
        if status.strip() in ("??", "M", "A", "MM", "AM"):
            files.append(filepath)
    return files


def extract_problem_number(filepath: str) -> str | None:
    stem = Path(filepath).stem
    match = re.search(r"_(\d+)$", stem)
    return match.group(1) if match else None


def git_add_commit_push(filepath: str, problem_number: str) -> bool:
    commit_msg = f"feat: LeetCode problem {problem_number}"
    try:
        subprocess.run(["git", "add", filepath], check=True)
        subprocess.run(["git", "commit", "-m", commit_msg], check=True)
        subprocess.run(["git", "push"], check=True)
        print(f"[OK] {filepath}  →  {commit_msg}")
        return True
    except subprocess.CalledProcessError as e:
        print(f"[ERROR] {filepath}: {e}", file=sys.stderr)
        return False


def main() -> None:
    files = get_unpushed_files()

    if not files:
        return

    for f in files:
        print(f"  {f}")
    print()

    ok = 0
    skip = 0
    for filepath in files:
        number = extract_problem_number(filepath)
        if number is None:
            skip += 1
            continue
        success = git_add_commit_push(filepath, number)
        ok += success

    print(f"\nDone: {ok} pushed, {skip} skipped.")


if __name__ == "__main__":
    main()
